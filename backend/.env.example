# App
APP_PORT=3001
APP_PREFIX=api/v1
NODE_ENV=development

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public"

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://127.0.0.1:6379/0

# Rate Limiting
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_TTL=60000

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-in-production
JWT_REFRESH_EXPIRES_IN=7d

# SePay Payment Gateway
SEPAY_MERCHANT_ID=your_merchant_id
SEPAY_SECRET_KEY=your_secret_key
SEPAY_ENV=sandbox
SEPAY_CALLBACK_BASE_URL=http://localhost:3001/api/v1

# Premium Pricing (VND)
PREMIUM_PRICE_MONTHLY=99000
PREMIUM_PRICE_QUARTERLY=249000
PREMIUM_PRICE_SEMI_ANNUAL=449000
PREMIUM_PRICE_ANNUAL=799000

# AI
AI_BASE_URL=http://160.22.123.174:2111/v1
AI_API_KEY=your_openai_compatible_api_key
AI_MODEL=gpt-5.4
